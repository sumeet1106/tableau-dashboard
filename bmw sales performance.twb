      <aliases enabled='yes' />
      <column caption='Total Revenue' datatype='integer' name='[Calculation_2413468157353984]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Price_USD]*[Sales_Volume])' />
      </column>
      <column caption='Total Sales' datatype='integer' name='[Calculation_2413468157566977]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales_Volume])' />
      </column>
      <column caption='AOV' datatype='real' name='[Calculation_2413468157722626]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Price_USD])' />
      </column>
      <column caption='Sales LY' datatype='integer' name='[Calculation_2413468158935045]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(SUM([Sales_Volume]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='YOY Growth %' datatype='real' name='[Calculation_2413468159086598]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([Sales_Volume]) &#13;&#10;- LOOKUP(SUM([Sales_Volume]), -1)&#13;&#10;)&#13;&#10;/&#13;&#10;LOOKUP(SUM([Sales_Volume]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
